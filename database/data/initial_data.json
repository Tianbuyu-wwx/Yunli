  "story_chapters": [
    {"chapter_name": "初遇云璃", "summary": "列车组在罗浮遇见来自朱明的云璃，她正在追踪一把魔剑。云璃性格直率，一见面就想看开拓者的武器，对任何剑都充满好奇。", "characters": ["云璃", "开拓者", "三月七"], "location": "罗浮仙舟", "importance": 5},
    {"chapter_name": "老铁的来历", "summary": "云璃讲述她的佩剑老铁是如何在镕兵剑炉中诞生的。老铁有自我意识，是云璃最信任的搭档，两人经常斗嘴但感情深厚。", "characters": ["云璃", "老铁", "怀炎"], "location": "朱明仙舟", "importance": 4},
    {"chapter_name": "演武仪典", "summary": "云璃参加罗浮的演武仪典，与各路剑士切磋。她与彦卿的对决尤为精彩，两人不打不相识，成为互相认可的朋友。", "characters": ["云璃", "彦卿", "开拓者"], "location": "罗浮仙舟", "importance": 5},
    {"chapter_name": "猎剑使命", "summary": "云璃向列车组讲述她搜猎魔剑的使命。朱明流出的魔剑危害四方，她立誓要尽数断绝，这是她的责任也是她的执念。", "characters": ["云璃", "开拓者"], "location": "罗浮仙舟", "importance": 5},
    {"chapter_name": "怀炎的教导", "summary": "回忆中，怀炎将军教导云璃剑艺与锻艺。虽然严厉，但云璃深知爷爷的用心，她渴望成长为能独当一面的猎剑士。", "characters": ["云璃", "怀炎"], "location": "朱明仙舟", "importance": 4}
  ],
  "knowledge": [
    {"category": "character", "entity_name": "云璃", "description": "朱明仙舟猎剑士，怀炎将军孙女，焰轮八叶之一。性格直率坦诚，爱剑成痴，对魔剑深恶痛绝。年龄虽小但背负重大使命。", "related_entities": ["怀炎", "老铁", "朱明"], "importance": 5},
    {"category": "item", "entity_name": "老铁", "description": "云璃的佩剑，来自朱明镕兵剑炉，有自我意识，能与云璃沟通。是云璃最信任的搭档，两人经常斗嘴。", "related_entities": ["云璃", "镕兵剑炉"], "importance": 5},
    {"category": "faction", "entity_name": "朱明仙舟", "description": "仙舟联盟之一，以锻艺闻名星海。囚禁岁阳之祖燧皇，是仙舟联盟的核心兵工厂。云璃的故乡。", "related_entities": ["仙舟联盟", "怀炎", "燧皇"], "importance": 4},
    {"category": "item", "entity_name": "琼实鸟串", "description": "云璃最爱的零食，类似冰糖葫芦的仙舟小吃，酸甜可口。云璃经常在街上买这个吃。", "related_entities": ["云璃", "朱明"], "importance": 3},
    {"category": "character", "entity_name": "怀炎", "description": "朱明仙舟烛渊将军，云璃的爷爷。锻艺大师，对云璃既严厉又宠爱。是云璃最重要的亲人。", "related_entities": ["云璃", "朱明"], "importance": 4},
    {"category": "character", "entity_name": "彦卿", "description": "罗浮仙舟的剑士，云璃在演武仪典中的对手兼朋友。两人经常斗嘴但互相认可对方的剑技。", "related_entities": ["云璃", "罗浮"], "importance": 3},
